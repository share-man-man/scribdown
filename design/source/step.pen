                        "vWdZg": {
                          "content": "01 const parser = createParser({ safeMode: true });\n02 const tokens = parser.tokenize(markdownSource);\n03 const blocks = normalizeBlocks(tokens);\n04 const diagnostics = [];\n05\n06 for (const block of blocks) {\n07   if (block.type === \"code\" && block.lang === \"mermaid\") {\n08     const result = validateMermaid(block.content);\n09     if (!result.ok) diagnostics.push(result.error);\n10   }\n11 }\n12\n13 const viewport = {\n14   width: 960,\n15   density: \"comfortable\",\n16   theme: \"paper-light\",\n17 };\n18\n19 function renderParagraph(text) {\n20   return {\n21     type: \"paragraph\",\n22     text,\n23     lineHeight: 1.75,\n24   };\n25 }\n26\n27 export function renderDocument(doc) {\n28   const sections = [];\n29   for (const node of doc.nodes) {\n30     sections.push(renderNode(node));\n31   }\n32   return { sections, diagnostics, viewport };\n33 }\n34\n35 // Long line for overflow behavior >>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>>\n36 // End of fixture"
